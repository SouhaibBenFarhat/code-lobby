{
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ESNext",
    "useDefineForClassFields": true,
    "declaration": true,
    "declarationMap": true,
    "isolatedDeclarations": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/renderer/*"],
      "@logger": ["./--module-logger/index.ts"],
      "@logger/*": ["./--module-logger/*"],
      "@slot-system": ["./--module-slot-system/index.tsx"],
      "@slot-system/*": ["./--module-slot-system/*"],
      "@data": ["./--module-data/index.ts"],
      "@data/*": ["./--module-data/*"],
      "@header": ["./--module-header/index.tsx"],
      "@header/*": ["./--module-header/*"],
      "@explorer": ["./--module-explorer/index.tsx"],
      "@explorer/*": ["./--module-explorer/*"],
      "@user-profile": ["./--module-user-profile/index.tsx"],
      "@user-profile/*": ["./--module-user-profile/*"],
      "@canvas": ["./--module-canvas/index.tsx"],
      "@canvas/*": ["./--module-canvas/*"],
      "@pr-detail": ["./--module-pr-detail/index.tsx"],
      "@pr-detail/*": ["./--module-pr-detail/*"],
      "@ai-chat": ["./--module-ai-chat/index.tsx"],
      "@ai-chat/*": ["./--module-ai-chat/*"],
      "@network": ["./--module-network/index.tsx"],
      "@network/*": ["./--module-network/*"],
      "@app": ["./--module-app/index.ts"],
      "@app/*": ["./--module-app/*"],
      "@ui-kit": ["./--module-ui-kit/index.ts"],
      "@ui-kit/*": ["./--module-ui-kit/*"],
      "@test-utils": ["./--module-test-utils/index.ts"],
      "@test-utils/*": ["./--module-test-utils/*"],
      "@persistence": ["./--module-persistence/index.ts"],
      "@persistence/*": ["./--module-persistence/*"]
    },
    "types": ["node", "vitest/globals", "@testing-library/jest-dom", "electron"],
    "outDir": "./out/renderer"
  },
  "include": ["src/renderer/**/*", "src/preload/electron-api.d.ts", "--module-*/**/*", "tests/**/*"],
  "exclude": ["--module-persistence/main/**/*", "--module-logger/main.ts", "--module-logger/main-logger.ts", "--module-logger/main-logger.test.ts"]
}
