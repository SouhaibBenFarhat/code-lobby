{
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ESNext",
    "useDefineForClassFields": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/renderer/*"],
      "@codelobby/slot-system": ["packages/slot-system/src/index.tsx"],
      "@codelobby/shared-store": ["packages/shared-store/src/index.ts"],
      "@codelobby/shared-store/*": ["packages/shared-store/src/*"],
      "@codelobby/data-module": ["packages/data-module/src/index.ts"],
      "@codelobby/header-module": ["packages/header-module/src/index.ts"],
      "@codelobby/explorer-module": ["packages/explorer-module/src/index.ts"],
      "@codelobby/canvas-module": ["packages/canvas-module/src/index.ts"],
      "@codelobby/pr-detail-module": ["packages/pr-detail-module/src/index.ts"],
      "@codelobby/ai-chat-module": ["packages/ai-chat-module/src/index.ts"],
      "@codelobby/app": ["packages/app/src/index.ts"],
      "@codelobby/app/bootstrap": ["packages/app/src/bootstrap.ts"],
      "@codelobby/ui-kit": ["packages/ui-kit/src/index.ts"]
    },
    "types": ["node"],
    "outDir": "./out/renderer"
  },
  "include": ["src/renderer/**/*", "src/preload/index.d.ts", "packages/**/*"]
}
