{
  "name": "codelobby",
  "version": "1.0.0",
  "description": "A desktop app to monitor your GitHub PRs with real-time event streaming",
  "main": "./out/main/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/SouhaibBenFarhat/code-lobby.git"
  },
  "author": "",
  "license": "MIT",
  "engines": {
    "pnpm": ">=10.0.0",
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-rebuild && electron-builder install-app-deps && node scripts/patch-electron-name.js",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "typecheck": "tsc -p tsconfig.web.json --emitDeclarationOnly --outDir .typecheck-temp && tsc --noEmit -p tsconfig.node.json && rm -rf .typecheck-temp",
    "lint": "biome check .",
    "lint:fix": "biome check --write --unsafe .",
    "format": "biome format --write .",
    "prepare": "husky",
    "generate:theme": "node scripts/generate-theme.mjs",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "sqlite_web \"$HOME/Library/Application Support/codelobby/codelobby.db\"",
    "db:open": "open -a 'DB Browser for SQLite' \"$HOME/Library/Application Support/codelobby/codelobby.db\"",
    "db:cli": "sqlite3 \"$HOME/Library/Application Support/codelobby/codelobby.db\"",
    "db:tables": "sqlite3 \"$HOME/Library/Application Support/codelobby/codelobby.db\" \".tables\"",
    "db:schema": "sqlite3 \"$HOME/Library/Application Support/codelobby/codelobby.db\" \".schema\"",
    "db:path": "echo \"$HOME/Library/Application Support/codelobby/codelobby.db\""
  },
  "dependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "@octokit/graphql": "^7.0.2",
    "@octokit/rest": "^20.0.2",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@tanstack/query-sync-storage-persister": "^5.90.22",
    "@tanstack/react-query": "^5.17.0",
    "@tanstack/react-query-persist-client": "^5.90.22",
    "@tanstack/react-virtual": "^3.13.18",
    "@types/react-grid-layout": "^1.3.6",
    "@uiw/react-md-editor": "^4.0.11",
    "better-sqlite3": "9.6.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.2.0",
    "drizzle-orm": "^0.45.1",
    "electron-context-menu": "^4.1.1",
    "electron-store": "^8.1.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.309.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-draggable": "^4.5.0",
    "react-grid-layout": "^2.2.2",
    "react-markdown": "^10.1.0",
    "react-rnd": "^10.5.2",
    "react-sketch-canvas": "^6.2.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@electron-toolkit/eslint-config-ts": "^1.0.1",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.2.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.9",
    "autoprefixer": "^10.4.16",
    "drizzle-kit": "^0.31.8",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^2.0.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vitest": "^2.1.9"
  },
  "build": {
    "appId": "com.codelobby.app",
    "productName": "CodeLobby",
    "publish": [
      {
        "provider": "github",
        "owner": "SouhaibBenFarhat",
        "repo": "code-lobby",
        "releaseType": "release"
      }
    ],
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "drizzle",
        "to": "drizzle",
        "filter": [
          "**/*.sql",
          "meta/**/*"
        ]
      }
    ],
    "mac": {
      "target": "dmg",
      "artifactName": "CodeLobby-${arch}.${ext}",
      "icon": "build/icon.icns",
      "extendInfo": "build/Info.plist"
    },
    "dmg": {
      "artifactName": "CodeLobby-${arch}.${ext}"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
