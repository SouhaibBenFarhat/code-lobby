{
  "$schema": "https://biomejs.dev/schemas/2.3.12/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "*.ts",
      "*.tsx",
      "src/**/*.ts",
      "src/**/*.tsx",
      "--module-*/**/*.ts",
      "--module-*/**/*.tsx",
      "tests/**/*.ts",
      "tests/**/*.tsx"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off",
        "noArrayIndexKey": "error"
      },
      "style": {
        "useImportType": "off",
        "noNonNullAssertion": "error",
        "noRestrictedImports": "off"
      },
      "a11y": {
        "noStaticElementInteractions": "error",
        "useKeyWithClickEvents": "error",
        "noSvgWithoutTitle": "error"
      },
      "correctness": {
        "useExhaustiveDependencies": "error",
        "noUnusedVariables": "error",
        "noUnusedImports": "error"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded",
      "trailingCommas": "none"
    }
  },
  "overrides": [
