{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ESNext",
    "outDir": "out",
    "declaration": true,
    "types": ["node"],
    "paths": {
      "@logger/main": ["./__module__logger/main.ts"],
      "@logger": ["./__module__logger/index.ts"]
    }
  },
  "include": [
    "electron.vite.config.ts",
    "src/main/**/*",
    "src/preload/**/*",
    "__module__logger/**/*"
  ]
}
