{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ESNext",
    "outDir": "out",
    "declaration": true,
    "types": ["node"],
    "paths": {
      "@logger/main": ["./--module-logger/main.ts"],
      "@logger": ["./--module-logger/index.ts"],
      "@persistence/main": ["./--module-persistence/main/index.ts"]
    }
  },
  "include": [
    "electron.vite.config.ts",
    "src/main/**/*",
    "src/preload/**/*",
    "--module-logger/**/*",
    "--module-persistence/main/**/*"
  ]
}
