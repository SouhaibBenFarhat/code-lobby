{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ESNext",
    "outDir": "out",
    "declaration": true,
    "types": ["node"],
    "paths": {
      "@codelobby/logger/main": ["./packages/logger/src/main.ts"],
      "@codelobby/logger": ["./packages/logger/src/index.ts"]
    }
  },
  "include": [
    "electron.vite.config.ts",
    "src/main/**/*",
    "src/preload/**/*",
    "packages/logger/src/**/*"
  ]
}
